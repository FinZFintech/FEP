# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── NextAuth ────────────────────────────────────────────────────────────────
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Data APIs ────────────────────────────────────────────────────────────────
# US College Scorecard — free, get key at https://api.data.gov/signup/
COLLEGE_SCORECARD_API_KEY=""

# BLS (Bureau of Labor Statistics) — free, register at https://data.bls.gov/registrationEngine/
BLS_API_KEY=""

# O*NET Web Services — free, register at https://services.onetcenter.org/developer
ONET_USERNAME=""
ONET_PASSWORD=""

# ─── Exchange Rates (INR per unit) ────────────────────────────────────────────
INR_PER_USD=83.5
INR_PER_GBP=106.0
INR_PER_CAD=61.5
INR_PER_AUD=54.0
INR_PER_EUR=90.0
INR_PER_NZD=50.0
INR_PER_SGD=62.0
INR_PER_SEK=7.8
