generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("credit_manager")
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  assessments Assessment[]
  batchJobs   BatchJob[]
  ruleSets    RuleSet[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Assessment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  studentName          String
  undergradInstitution String
  undergradTier        String
  undergradDegree      String
  undergradMajor       String
  undergradCgpa        Float
  greScore             Int?
  gmatScore            Int?
  workExperienceYears  Int   @default(0)

  destinationCountry    String
  destinationUniversity String
  targetDegree          String
  targetCourse          String
  isStem                Boolean @default(false)
  programDurationMonths Int     @default(24)
  targetCity            String?

  loanAmountInr Float?

  ruleSetVersion String?

  epScore     Float
  epRiskBand  String
  epBreakdown String  @db.Text

  fipYear1Local Float
  fipYear3Local Float
  fipYear5Local Float
  fipYear1Inr   Float
  fipYear3Inr   Float
  fipYear5Inr   Float
  fipCurrency   String
  fipBreakdown  String  @db.Text

  notes      String?  @db.Text
  batchJobId String?
  batchJob   BatchJob? @relation(fields: [batchJobId], references: [id])
}

model BatchJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  fileName  String
  rowCount  Int
  status    String   @default("pending")
  errorMsg  String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  assessments Assessment[]
}

model RuleSet {
  id            String   @id @default(cuid())
  version       String   @unique
  name          String
  status        String   @default("draft")
  parameters    String   @db.Text
  changeSummary String?  @db.Text
  createdAt     DateTime @default(now())
  publishedAt   DateTime?
  archivedAt    DateTime?

  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id])

  @@index([status])
}
