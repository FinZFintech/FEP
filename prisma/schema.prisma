generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("credit_manager")
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  assessments Assessment[]
  batchJobs   BatchJob[]
  ruleSets    RuleSet[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Assessment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  studentName          String
  undergradInstitution String
  undergradTier        String
  undergradDegree      String
  undergradMajor       String
  undergradCgpa        Float
  greScore             Int?
  gmatScore            Int?
  workExperienceYears  Int   @default(0)

  destinationCountry    String
  destinationUniversity String
  targetDegree          String
  targetCourse          String
  isStem                Boolean @default(false)
  programDurationMonths Int     @default(24)
  targetCity            String?

  loanAmountInr Float?

  ruleSetVersion String?

  epScore     Float
  epRiskBand  String
  epBreakdown String  @db.Text

  fipYear1Local Float
  fipYear3Local Float
  fipYear5Local Float
  fipYear1Inr   Float
  fipYear3Inr   Float
  fipYear5Inr   Float
  fipCurrency   String
  fipBreakdown  String  @db.Text

  // ── Framework §12 (Credit), §13 (Income Stability), §15 (Savings) ──────
  // Applicant credit and income (co-applicants live in CoApplicant model)
  applicantCibilScore      Int?
  applicantCrifScore       Int?
  applicantAnnualSalary    Float?
  applicantAnnualOther     Float?
  applicantExistingEmis    Float[] @default([])
  applicantFutureEmiInr    Float?
  isNewToCredit            Boolean @default(false)
  averageBankBalance3moInr Float?

  // Savings / skin-in-the-game (§15)
  tuitionFeesInr       Float?
  livingExpensesInr    Float?
  totalCostOfAttInr    Float?
  scholarshipInr       Float  @default(0)
  mutualFundInr        Float  @default(0)
  fdInr                Float  @default(0)
  bankSavingsInr       Float  @default(0)
  otherSavingsInr      Float  @default(0)

  // ── Framework §4.2 Penalty flags (manual check-points) ─────────────────
  addressPincode              String?
  inNegativePincodeList       Boolean @default(false)
  documentAuthenticityStatus  String? // VERIFIED | PARTIAL | MISMATCH | FORGERY | UNVERIFIABLE
  admissionVisaFlightStatus   String? // ALL_CONFIRMED | VISA_IN_PROCESS | CONDITIONAL | LIKELY_REJECT | FAKE
  socialMediaRedFlag          Boolean @default(false)
  creditDefault15PlusDpd      Boolean @default(false)
  creditDefaultWriteOff       Boolean @default(false)
  creditOverdueAbove3k        Boolean @default(false)
  earlyEmiBounceHistory       Boolean @default(false)
  consultantBlacklistHit      Boolean @default(false)

  // ── Framework §25 Insurance ────────────────────────────────────────────
  insuranceBundle String? // LIFE_ACC_HEALTH | LIFE_ACC | CREDIT_LIFE_ONLY | DECLINED | NONE

  // ── Composite scorecard outputs (Framework §4.1, §5) ───────────────────
  compositeScore     Float?
  compositeDecision  String? // APPROVE | CAUTION | REJECT
  compositeBreakdown String? @db.Text // JSON

  coApplicants CoApplicant[]

  notes      String?  @db.Text
  batchJobId String?
  batchJob   BatchJob? @relation(fields: [batchJobId], references: [id])
}

/// Framework §13, §14 — co-applicant details for income stability and source.
/// Hard cap of 3 enforced at the API layer.
model CoApplicant {
  id           String @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  relation       String  // FATHER | MOTHER | SPOUSE | SIBLING | GUARDIAN
  occupationType String  // PRIVATE | GOVT | SELF_EMPLOYED | NOT_WORKING | RETIRED | FARMER

  cibilScore     Int?
  crifScore      Int?

  annualSalary   Float  @default(0)
  annualRental   Float  @default(0)
  annualOther    Float  @default(0)
  existingEmis   Float[] @default([])

  @@index([assessmentId])
}

model BatchJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  fileName  String
  rowCount  Int
  status    String   @default("pending")
  errorMsg  String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  assessments Assessment[]
}

model RuleSet {
  id            String   @id @default(cuid())
  version       String   @unique
  name          String
  status        String   @default("draft")
  parameters    String   @db.Text
  changeSummary String?  @db.Text
  createdAt     DateTime @default(now())
  publishedAt   DateTime?
  archivedAt    DateTime?

  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id])

  @@index([status])
}
